<?xml version="1.0"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<configuration>
  <!--
    Autorise l'utilisateur technique Hue a proxifier les utilisateurs
    applicatifs dans cette stack locale Docker quand le profil UI est active.
    Necessaire car Hue envoie hive.server2.proxy.user pour l'editeur Hive.
  -->
  <property>
    <name>hadoop.proxyuser.hue.hosts</name>
    <value>*</value>
  </property>
  <property>
    <name>hadoop.proxyuser.hue.groups</name>
    <value>*</value>
  </property>
</configuration>
