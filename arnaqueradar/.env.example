# =============================================================================
# PostgreSQL LOCAL (pgAdmin4)
# Remplissez PG_USER et PG_PASSWORD avec vos identifiants pgAdmin4 locaux.
# Par défaut pgAdmin4 installe PostgreSQL avec l'utilisateur 'postgres'.
# Créez la base 'arnaqueradar' via pgAdmin4 avant de lancer le pipeline.
# =============================================================================
PG_HOST=localhost
PG_PORT=5432
PG_DB=arnaqueradar
PG_USER=postgres
PG_PASSWORD=MOT_DE_PASSE_PGADMIN4
# Hue utilise PostgreSQL au lieu de SQLite pour eviter les verrous `database is locked`.
# Par defaut, le conteneur pointe vers le PostgreSQL local de la machine via host.docker.internal
# et reutilise PG_DB / PG_USER / PG_PASSWORD. Vous pouvez surcharger separement si besoin.
HUE_DB_ENGINE=postgresql_psycopg2
HUE_DB_HOST=host.docker.internal
# HUE_DB_PORT=5432
# HUE_DB_NAME=arnaqueradar
# HUE_DB_USER=postgres
# HUE_DB_PASSWORD=MOT_DE_PASSE_PGADMIN4
# Import SQL massif : bornage du nombre de groupes consolides par transaction
# pour eviter `max_locks_per_transaction` sur les gros jeux de donnees.
PG_IMPORT_COMMIT_EVERY_GROUPS=200
PG_IMPORT_PROGRESS_EVERY_GROUPS=1000

# =============================================================================
# Apache Hive (Big Data)
# Source 5 : collect/collecter.py lit uniquement Hive.
# Le chargement massif PhishStats -> Hive se fait a part via :
#   python -m collect.bootstrap_hive_phishstats --target 50000
# =============================================================================
HIVE_HOST=localhost
HIVE_PORT=10000
HIVE_USER=hive
HIVE_DB=default
HIVE_AUTH=NOSASL
PHISHSTATS_API_URL=https://api.phishstats.info/api/phishing
HIVE_PHISHSTATS_TARGET_ROWS=50000
HIVE_PHISHSTATS_PAGE_SIZE=100
HIVE_PHISHSTATS_REQUEST_DELAY_SECONDS=6.5
HIVE_PHISHSTATS_RETRY_AFTER_SECONDS=60
HIVE_PHISHSTATS_FORCE_REFRESH=false
HIVE_CACHE_MAX_AGE_HOURS=24
HIVE_QUERY_MODE=rows
HIVE_FILTER_CURRENT_YEAR=false

# =============================================================================
# Sources de collecte
# =============================================================================
# URLhaus : feeds historiques officiels par pays, bornes sous 15k entrees.
# L'Auth-Key reste utile uniquement pour le fallback `recent` de l'API.
URLHAUS_AUTH_KEY=VOTRE_AUTH_KEY_URLHAUS
URLHAUS_RECENT_LIMIT=100
URLHAUS_MAX_ENTRIES=14999
URLHAUS_FEED_COUNTRIES=FR,DE,NL,CH,PL,IT,ES,GB,BE,AT,CZ,RO,UA,SE,NO,DK,CA,AU,JP,SG,BR,PT,IE,HU,GR,SK,FI,BG,LT,LV
# MalwareTips : scraping HTML des Scam Reports, borne sous 10k entrees
MALWARETIPS_MAX_ENTRIES=10000
# CNIL CSV : retéléchargement uniquement si le fichier local est plus ancien
# que ce seuil (en jours)
CNIL_MAX_AGE_DAYS=30

# =============================================================================
# API REST (FastAPI)
# Générez SECRET_KEY avec : python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
DATABASE_URL=postgresql://postgres:VOTRE_MOT_DE_PASSE_PGADMIN4@localhost/arnaqueradar
ADMIN_USERNAME=admin
ADMIN_PASSWORD=arnaqueradar2024
