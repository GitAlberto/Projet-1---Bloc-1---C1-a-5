# =============================================================================
# PostgreSQL LOCAL (pgAdmin4)
# Remplissez PG_USER et PG_PASSWORD avec vos identifiants pgAdmin4 locaux.
# Par défaut pgAdmin4 installe PostgreSQL avec l'utilisateur 'postgres'.
# Créez la base 'arnaqueradar' via pgAdmin4 avant de lancer le pipeline.
# =============================================================================
PG_HOST=localhost
PG_PORT=5432
PG_DB=arnaqueradar
PG_USER=postgres
PG_PASSWORD=VOTRE_MOT_DE_PASSE_PGADMIN4

# =============================================================================
# Apache Hive (Big Data) — optionnel, fallback automatique si indisponible
# =============================================================================
HIVE_HOST=localhost
HIVE_PORT=10000
HIVE_USER=hive
HIVE_DB=default
HIVE_AUTH=NOSASL

# =============================================================================
# Sources de collecte
# =============================================================================
# Google Web Risk : API Lookup stricte. Le connecteur verifie une liste locale
# d'URLs candidates et ne conserve que les reponses SOCIAL_ENGINEERING.
GOOGLE_WEB_RISK_API_KEY=VOTRE_CLE_API_GOOGLE_WEB_RISK
GOOGLE_WEB_RISK_CANDIDATES_PATH=data/google_web_risk_candidates.txt

# =============================================================================
# API REST (FastAPI)
# Générez SECRET_KEY avec : python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
DATABASE_URL=postgresql://postgres:VOTRE_MOT_DE_PASSE_PGADMIN4@localhost/arnaqueradar
ADMIN_USERNAME=admin
ADMIN_PASSWORD=arnaqueradar2024
